# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never exposed to the browser

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8

# Netlify — cuenta de Andrés, para el deploy inmediato de la landing (paso 1 de D5)
NETLIFY_AUTH_TOKEN=

# Resend — notificaciones por email. El dominio del remitente debe estar verificado en Resend.
RESEND_API_KEY=
EMAIL_FROM=Cállate y Lanza <andres@authomata.ai>

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
